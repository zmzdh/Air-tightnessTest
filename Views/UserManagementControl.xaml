<UserControl x:Class="AudioActuatorCanTest.UserControls.UserManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#2E3440"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧用户列表 -->
        <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,10,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="用户管理" Style="{StaticResource SectionTitleStyle}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Name="BtnAddUser" Content="添加用户" 
                           Style="{StaticResource ActionButtonStyle}"
                           Background="#A3BE8C" Foreground="White"
                           Click="BtnAddUser_Click"/>
                    <Button Name="BtnEditUser" Content="编辑用户" 
                           Style="{StaticResource ActionButtonStyle}"
                           Background="#5E81AC" Foreground="White"
                           Click="BtnEditUser_Click"/>
                    <Button Name="BtnDeleteUser" Content="删除用户" 
                           Style="{StaticResource ActionButtonStyle}"
                           Background="#BF616A" Foreground="White"
                           Click="BtnDeleteUser_Click"/>
                    <Button Name="BtnResetPassword" Content="重置密码" 
                           Style="{StaticResource ActionButtonStyle}"
                           Background="#D08770" Foreground="White"
                           Click="BtnResetPassword_Click"/>
                    <Button Name="BtnRefresh" Content="刷新" 
                           Style="{StaticResource ActionButtonStyle}"
                           Background="#88C0D0" Foreground="White"
                           Click="BtnRefresh_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="2" Name="UsersDataGrid" AutoGenerateColumns="False"
                         CanUserAddRows="False" CanUserDeleteRows="False"
                         SelectionMode="Single" GridLinesVisibility="Horizontal"
                         AlternatingRowBackground="#F8F9FA"
                         SelectionChanged="UsersDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="姓名" Binding="{Binding FullName}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="角色" Binding="{Binding Role}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Role}" Value="Admin">
                                            <Setter Property="Foreground" Value="#BF616A"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="Engineer">
                                            <Setter Property="Foreground" Value="#D08770"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="Operator">
                                            <Setter Property="Foreground" Value="#5E81AC"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="120" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 右侧用户详情 -->
        <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Name="UserDetailPanel">
                    <TextBlock Text="用户详情" Style="{StaticResource SectionTitleStyle}"/>

                    <!-- 基本信息 -->
                    <GroupBox Header="基本信息" Margin="0,0,0,20">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名:" Margin="5" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="TxtUsername" Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="姓名:" Margin="5" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Name="TxtFullName" Margin="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="角色:" Margin="5" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Name="CmbRole" Margin="5">
                                <ComboBoxItem Content="操作员" Tag="Operator"/>
                                <ComboBoxItem Content="工程师" Tag="Engineer"/>
                                <ComboBoxItem Content="管理员" Tag="Admin"/>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="部门:" Margin="5" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" Name="CmbDepartment" Margin="5" IsEditable="True">
                                <ComboBoxItem Content="生产部"/>
                                <ComboBoxItem Content="质量部"/>
                                <ComboBoxItem Content="技术部"/>
                                <ComboBoxItem Content="管理部"/>
                                <ComboBoxItem Content="设备部"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="邮箱:" Margin="5" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Name="TxtEmail" Margin="5"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="启用状态:" Margin="5" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" Name="ChkIsActive" Content="启用" Margin="5"/>
                        </Grid>
                    </GroupBox>

                    <!-- 权限设置 -->
                    <GroupBox Header="权限设置" Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <TextBlock Text="功能权限:" FontWeight="Bold" Margin="0,0,0,10"/>
                            <CheckBox Name="ChkCanTest" Content="测试权限" Margin="5"/>
                            <CheckBox Name="ChkCanManual" Content="手动调试权限" Margin="5"/>
                            <CheckBox Name="ChkCanConfig" Content="参数配置权限" Margin="5"/>
                            <CheckBox Name="ChkCanReport" Content="报告查看权限" Margin="5"/>
                            <CheckBox Name="ChkCanUserManage" Content="用户管理权限" Margin="5"/>
                            <CheckBox Name="ChkCanSystemSettings" Content="系统设置权限" Margin="5"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 密码设置 -->
                    <GroupBox Header="密码设置" Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="新密码:" Width="60" VerticalAlignment="Center"/>
                                <PasswordBox Name="PwdNew" Width="150" Margin="5"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="确认密码:" Width="60" VerticalAlignment="Center"/>
                                <PasswordBox Name="PwdConfirm" Width="150" Margin="5"/>
                            </StackPanel>
                            <TextBlock Text="留空表示不修改密码" FontSize="10" Foreground="Gray" Margin="5"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                        <Button Name="BtnSaveUser" Content="保存" Width="80" Height="35"
                               Background="#A3BE8C" Foreground="White" FontSize="14"
                               Click="BtnSaveUser_Click"/>
                        <Button Name="BtnCancelEdit" Content="取消" Width="80" Height="35"
                               Background="#BF616A" Foreground="White" FontSize="14"
                               Margin="20,0,0,0" Click="BtnCancelEdit_Click"/>
                    </StackPanel>

                    <!-- 用户统计信息 -->
                    <GroupBox Header="统计信息" Margin="0,20,0,0">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="创建时间:" Margin="5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Name="TxtCreatedAt" Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="最后登录:" Margin="5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Name="TxtLastLoginAt" Margin="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="登录次数:" Margin="5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Name="TxtLoginCount" Margin="5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="测试次数:" Margin="5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Name="TxtTestCount" Margin="5"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>