<UserControl x:Class="AudioActuatorCanTest.Views.AutoTest.MassageTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignWidth="520"
             d:DesignHeight="360">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="MassageConfigGrid"
                  ItemsSource="{Binding ItemsSource, ElementName=Root}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  HeadersVisibility="Column"
                  Margin="0,0,0,10"
                  Height="240">
            <DataGrid.Columns>
                <DataGridTextColumn Header="点位"
                                    Binding="{Binding Point, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="60"/>
                <DataGridTextColumn Header="左通道气压开关"
                                    Binding="{Binding LeftPressureSwitchAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150"/>
                <DataGridTextColumn Header="右通道气压开关"
                                    Binding="{Binding RightPressureSwitchAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Header="共享参数" Margin="0,0,0,5">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="按摩动作总时长" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,5,5"
                         Text="{Binding Settings.TotalDuration, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="毫秒" VerticalAlignment="Center" Margin="0,0,5,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="高电平时长下限" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,5,5"
                         Text="{Binding Settings.HighLevelDurationMin, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="高电平时长上限" VerticalAlignment="Center" Margin="10,0,5,5"/>
                <TextBox Grid.Row="1" Grid.Column="4" Margin="0,0,5,5"
                         Text="{Binding Settings.HighLevelDurationMax, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="峰值电流下限" VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,5,5"
                         Text="{Binding Settings.PeakCurrentMin, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="峰值电流上限" VerticalAlignment="Center" Margin="10,0,5,5"/>
                <TextBox Grid.Row="2" Grid.Column="4" Margin="0,0,5,5"
                         Text="{Binding Settings.PeakCurrentMax, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="平均电流下限" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,5,0"
                         Text="{Binding Settings.AverageCurrentMin, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="3" Grid.Column="3" Text="平均电流上限" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <TextBox Grid.Row="3" Grid.Column="4" Margin="0,0,5,0"
                         Text="{Binding Settings.AverageCurrentMax, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
