<UserControl x:Class="AudioActuatorCanTest.UserControls.ModelConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧型号列表 -->
        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="产品型号" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Name="BtnAddModel" Content="新增" Width="60" Margin="0,0,5,0"
                           Click="BtnAddModel_Click"/>
                    <Button Name="BtnDeleteModel" Content="删除" Width="60" Margin="5,0,0,0"
                           Click="BtnDeleteModel_Click"/>
                </StackPanel>

                <!-- 新增导入导出按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Name="BtnImportConfig" Content="导入配置" Width="80" Margin="0,0,5,0"
                           Click="BtnImportConfig_Click" Background="#FF0078D7" Foreground="White"/>
                    <Button Name="BtnExportConfig" Content="导出配置" Width="80" Margin="5,0,0,0"
                           Click="BtnExportConfig_Click" Background="#FF107C10" Foreground="White"/>
                </StackPanel>

                <ListBox Name="ModelListBox" Height="700"
                        SelectionChanged="ModelListBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- 右侧配置详情 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Margin="10" CornerRadius="5" Padding="20">
                <StackPanel Name="ConfigPanel">
                    <!-- 基本信息与流程配置合并为一行两列 -->
                    <GroupBox Header="基本信息与流程配置" Margin="0,0,0,20">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 基本信息列 (左侧) -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="型号名称:" VerticalAlignment="Center" Margin="5"/>
                                <TextBox Name="TxtModelName" Margin="5" Height="25"/>

                                <TextBlock Text="型号描述:" VerticalAlignment="Center" Margin="5,10,5,5"/>
                                <TextBox Name="TxtModelDesc" Margin="5" Height="25"/>

                                <TextBlock Text="型号图片:" VerticalAlignment="Center" Margin="5,10,5,5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBox Name="TxtImagePath" Width="200" Margin="0,0,10,0" Height="25"/>
                                    <Button Name="BtnSelectImage" Content="选择图片" Width="80" Height="25"
                       Click="BtnSelectImage_Click"/>
                                </StackPanel>

                                <Image Name="ModelImage" Height="120" Stretch="Uniform"
                  HorizontalAlignment="Left" Margin="5,10,5,5"/>
                            </StackPanel>

                            <!-- 流程配置列 (右侧) -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <CheckBox Name="ChkEnableBarcode" Content="启用扫码检查" Margin="5"/>
                                <CheckBox Name="ChkEnableCurrentMonitor" Content="启用电流监控" Margin="5"/>
                                <CheckBox Name="ChkRecordCurrentBeforeStart" Content="启动前记录电流" Margin="5"/>
                                <CheckBox Name="ChkEnableLumbarTest" Content="启用腰托测试" Margin="5"/>
                                <CheckBox Name="ChkEnableMassageTest" Content="启用按摩测试" Margin="5"/>
                                <CheckBox Name="ChkCheckSameModel" Content="主副驾同款检查" Margin="5"/>
                                <CheckBox Name="ChkPromptOnDuplicate" Content="重复扫码提示" Margin="5"/>
                                <CheckBox Name="ChkMeasureSleepCurrent" Content="测量休眠电流" Margin="5"/>
                                <CheckBox Name="ChkMeasureStaticCurrent" Content="测量静态电流" Margin="5"/>

                                <StackPanel Orientation="Horizontal" Margin="5,10,5,5">
                                    <TextBlock Text="最大重测次数:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Name="TxtMaxTestCount" Width="60" Margin="10,0,0,0" Height="25"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="主副驾断电(ms):" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Name="TxtPowerOffDuration" Width="80" Margin="10,0,0,0" Height="25"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- 通道配置 -->
                    <StackPanel Margin="0,0,0,20">
                        <GroupBox Header="电流与休眠参数" Margin="0,0,0,15">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="左通道" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="静态电流:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtLeftStaticMin" Width="80" Height="25"/>
                                        <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtLeftStaticMax" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="工作电流:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtLeftWorkMin" Width="80" Height="25"/>
                                        <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtLeftWorkMax" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="电流超限:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtLeftCurrentOver" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="休眠阈值:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtLeftSleepThreshold" Width="80" Height="25"/>
                                        <TextBlock Text="超时(ms):" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtLeftSleepTimeout" Width="80" Height="25"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <TextBlock Text="右通道" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="静态电流:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtRightStaticMin" Width="80" Height="25"/>
                                        <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtRightStaticMax" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="工作电流:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtRightWorkMin" Width="80" Height="25"/>
                                        <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtRightWorkMax" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="电流超限:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtRightCurrentOver" Width="80" Height="25"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="休眠阈值:" VerticalAlignment="Center" Width="90"/>
                                        <TextBox Name="TxtRightSleepThreshold" Width="80" Height="25"/>
                                        <TextBlock Text="超时(ms):" Margin="10,0" VerticalAlignment="Center"/>
                                        <TextBox Name="TxtRightSleepTimeout" Width="80" Height="25"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <!-- 保存按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                        <Button Name="BtnSaveModel" Content="保存配置" Width="100" Height="35"
                               Background="Green" Foreground="White" FontSize="14"
                               Click="BtnSaveModel_Click"/>
                        <Button Name="BtnReloadModel" Content="重新加载" Width="100" Height="35"
                               Background="Blue" Foreground="White" FontSize="14"
                               Margin="20,0,0,0" Click="BtnReloadModel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
