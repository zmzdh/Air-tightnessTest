<Window x:Class="AudioActuatorCanTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="上海舒井汽车汽车音律控制盒烧录检测系统" Height="1030" Width="1920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E3440"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3B4252"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#434C5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0" Background="#2E3440">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 导航按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnTest" Content="测试界面" Style="{StaticResource NavButtonStyle}"
                Click="BtnTest_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnManual" Content="手动调试" Style="{StaticResource NavButtonStyle}"
                Click="BtnManual_Click" FontSize="22" Visibility="Collapsed"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnModel" Content="机型配方" Style="{StaticResource NavButtonStyle}"
                Click="BtnModel_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnReport" Content="生产报表" Style="{StaticResource NavButtonStyle}" 
                Click="BtnReport_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnUser" Content="用户管理" Style="{StaticResource NavButtonStyle}"
                Click="BtnUser_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnSystemSettings" Content="系统设置" Style="{StaticResource NavButtonStyle}"
                Click="BtnSystemSettings_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnHelp" Content="使用帮助" Style="{StaticResource NavButtonStyle}"
                Click="BtnHelp_Click" FontSize="22"/>
                    </Border>
                    <Border BorderBrush="Gray" BorderThickness="2" Margin="4" CornerRadius="3">
                        <Button Name="BtnSystemLog" Content="系统日志" Style="{StaticResource NavButtonStyle}"
                Click="BtnSystemLog_Click" FontSize="22"/>
                    </Border>
                </StackPanel>

                <!-- 用户信息 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Name="TxtCurrentUser" Text="当前用户: 未登录" Foreground="White" Style="{StaticResource StatusStyle}"/>
                    <Button Name="BtnLogout" Content="注销" Style="{StaticResource NavButtonStyle}" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <ContentControl Name="MainContentControl" Grid.Row="1" Background="#ECEFF4"/>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#4C566A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="TxtStatus" Text="系统就绪" Foreground="White" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="1" Name="TxtMesStatusBar" Text="MES: 未连接" Foreground="Red" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="2" Name="TxtTime" Foreground="White" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="3" Text="版本: v1.4.3" Foreground="White" Style="{StaticResource StatusStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>