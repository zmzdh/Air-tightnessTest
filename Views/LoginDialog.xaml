<Window x:Class="AudioActuatorCanTest.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioActuatorCanTest.Views"
        mc:Ignorable="d"
        Title="LoginDialog" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Background="#ECEFF4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="上海舒井音律控制盒烧录检测系统"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,20,0,10"
                   Foreground="#2E3440"/>
        <!-- 登录表单 -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Margin="40,20" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="用户名:" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox Grid.Row="1" Name="CmbUsername" FontSize="14" Padding="5"
                          Margin="0,0,0,15" IsEditable="True" IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True" SelectionChanged="CmbUsername_SelectionChanged"
                          LostFocus="CmbUsername_LostFocus"/>
                <TextBlock Grid.Row="2" Text="密码:" FontSize="14" Margin="0,0,0,5"/>
                <PasswordBox Grid.Row="3" Name="TxtPassword" FontSize="14" Padding="5"
                            Margin="0,0,0,15"/>
                <CheckBox Grid.Row="4" Name="ChkRememberPassword" Content="记住密码"
                          FontSize="13"/>
            </Grid>
        </Border>
        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Name="BtnLogin" Content="登录" Width="80" Height="35"
                    Margin="10,0" Click="BtnLogin_Click"
                    Background="#5E81AC" Foreground="White"
                    BorderThickness="0" FontSize="14"/>
            <Button Name="BtnCancel" Content="取消" Width="80" Height="35"
                    Margin="10,0" Click="BtnCancel_Click"
                    Background="#BF616A" Foreground="White"
                    BorderThickness="0" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
