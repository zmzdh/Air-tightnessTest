<UserControl x:Class="AudioActuatorCanTest.UserControls.SystemSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="#ECEFF4">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,20">
            <TextBlock Text="系统设置" FontSize="28" FontWeight="Bold" Foreground="#2E3440" />
            <TextBlock Text="（仅管理员可操作）" FontSize="16" Foreground="#4C566A" Margin="20,8,0,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Modbus RTU 设置" FontSize="20" Grid.Column="0" Margin="0,0,20,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="串口号 (自动扫描)" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbModbusPortName" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" IsEditable="True" />

                    <TextBlock Text="波特率" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusBaudRate" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="数据位" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusDataBits" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="校验位 (N/E/O)" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusParity" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="停止位" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusStopBits" Grid.Row="8" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="电源设备地址" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusPowerDeviceAddress" Grid.Row="10" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="开关设备地址" Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusSwitchDeviceAddress" Grid.Row="12" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="读超时 (ms)" Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusReadTimeout" Grid.Row="14" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="电压寄存器地址" Grid.Row="16" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusVoltageRegister" Grid.Row="16" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="电流寄存器地址" Grid.Row="18" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusCurrentRegister" Grid.Row="18" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="电源控制寄存器" Grid.Row="20" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusPowerControlRegister" Grid.Row="20" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="短路线圈地址" Grid.Row="22" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusShortCircuitCoil" Grid.Row="22" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="断路线圈地址" Grid.Row="24" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusOpenCircuitCoil" Grid.Row="24" Grid.Column="1" Height="36" FontSize="16" />

                    <StackPanel Grid.Row="26" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnSaveConfig" Content="保存配置" Width="120" Height="36" FontSize="16" Click="BtnSaveConfig_Click" Margin="0,0,12,0" />
                        <Button x:Name="BtnReloadConfig" Content="重新加载" Width="120" Height="36" FontSize="16" Click="BtnReloadConfig_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="MES 系统" FontSize="20" Grid.Column="1" Margin="20,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="对接模式" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbMesMode" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesIp" Text="MES IP 地址" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtMesIp" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesPort" Text="端口号" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtMesPort" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesProtocol" Text="通信协议" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbMesProtocol" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblModbusIp" Text="Modbus 绑定地址" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusIp" Grid.Row="8" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblModbusPort" Text="Modbus 端口" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusPort" Grid.Row="10" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="TxtMesStatus" Grid.Row="12" Grid.ColumnSpan="2" FontSize="16" Foreground="Red" Text="MES 状态：未启用" />

                    <StackPanel x:Name="HttpButtonPanel" Grid.Row="14" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnMesConnect" Content="启用" Width="100" Height="36" FontSize="16" Click="BtnMesConnect_Click" Margin="0,0,12,0" />
                        <Button x:Name="BtnMesDisconnect" Content="停用" Width="100" Height="36" FontSize="16" Click="BtnMesDisconnect_Click" IsEnabled="False" Margin="0,0,12,0" />
                        <Button x:Name="BtnMesSimulatePush" Content="模拟推送" Width="120" Height="36" FontSize="16" Click="BtnMesSimulatePush_Click" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
