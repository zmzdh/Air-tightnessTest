<Window x:Class="AudioActuatorCanTest.Views.AddModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加新型号" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Background="#ECEFF4">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" 
                Margin="20" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="型号名称:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" Name="TxtModelName" FontSize="14" Padding="5" 
                         Margin="0,0,0,15"/>

                <TextBlock Grid.Row="2" Text="型号描述:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox Grid.Row="3" Name="TxtModelDesc" FontSize="14" Padding="5" 
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Name="BtnOK" Content="确定" Width="80" Height="35" 
                    Margin="10,0" Click="BtnOK_Click"
                    Background="#5E81AC" Foreground="White" 
                    BorderThickness="0" FontSize="14"/>
            <Button Name="BtnCancel" Content="取消" Width="80" Height="35" 
                    Margin="10,0" Click="BtnCancel_Click"
                    Background="#BF616A" Foreground="White" 
                    BorderThickness="0" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>

