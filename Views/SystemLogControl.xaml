<UserControl x:Class="AudioActuatorCanTest.UserControls.SystemLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Background="#ECEFF4" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="系统日志" FontSize="24" FontWeight="Bold" Margin="0,0,20,0" />
            <Button Content="刷新" Width="100" Height="32" Margin="0,0,10,0" Click="RefreshButton_Click" />
            <Button Content="清空显示" Width="100" Height="32" Click="ClearButton_Click" />
            <TextBlock Text="仅显示" Margin="30,0,10,0" VerticalAlignment="Center" />
            <ComboBox Width="150" SelectedIndex="0" VerticalAlignment="Center" SelectionChanged="LevelFilter_SelectionChanged" x:Name="LevelFilter">
                <ComboBoxItem Content="全部" Tag="All" IsSelected="True" />
                <ComboBoxItem Content="信息" Tag="Info" />
                <ComboBoxItem Content="警告" Tag="Warning" />
                <ComboBoxItem Content="错误" Tag="Error" />
            </ComboBox>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" BorderBrush="#D8DEE9" BorderThickness="1">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8" Background="#F8F9FB" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" >
                                    <TextBlock Text="[" Foreground="#4C566A" />
                                    <TextBlock Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Foreground="#4C566A" />
                                    <TextBlock Text="]" Foreground="#4C566A" Margin="2,0" />
                                    <TextBlock Text="[" Foreground="#4C566A" />
                                    <TextBlock Text="{Binding Level}" Margin="0,0,0,0" Foreground="{Binding LevelColor}" FontWeight="Bold" />
                                    <TextBlock Text="]" Foreground="#4C566A" Margin="2,0" />
                                    <TextBlock Text="{Binding Message}" Margin="10,0,0,0" TextWrapping="Wrap" Foreground="#2E3440" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
