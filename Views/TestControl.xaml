<UserControl x:Class="AudioActuatorCanTest.UserControls.TestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TestButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <DataTemplate x:Key="StageTemplate">
            <Border Margin="2" Padding="8" CornerRadius="4" Background="{Binding StateBackground}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="{Binding IndicatorBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StateDescription}" FontSize="12" Margin="10,0,0,0" Foreground="{Binding StateForeground}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧工单信息 -->
        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="5">
            <StackPanel Margin="15">
                <TextBlock Text="工单与扫码" FontSize="16" FontWeight="Bold"
                          Foreground="#2E3440" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="工单号:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TxtWorkOrder" Margin="5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="产品型号:" Style="{StaticResource InfoLabelStyle}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Name="CmbProductModel" Margin="5"
                             SelectionChanged="CmbProductModel_SelectionChanged" DisplayMemberPath="ModelName"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="操作员:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Name="TxtOperator" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="测试次数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Name="TxtTestCount" Text="0" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="合格数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Name="TxtPassCount" Text="0" Style="{StaticResource InfoValueStyle}" Foreground="Green"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="不合格数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Name="TxtFailCount" Text="0" Style="{StaticResource InfoValueStyle}" Foreground="Red"/>
                </Grid>

                <Separator Margin="0,15"/>

                <StackPanel>
                    <TextBlock Text="产品扫码" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox Name="TxtProductCode" FontSize="16" Padding="5" Margin="0,0,0,5"
                            InputMethod.IsInputMethodEnabled="False"
                            PreviewKeyDown="TxtProductCode_PreviewKeyDown"
                            PreviewTextInput="TxtProductCode_PreviewTextInput"
                            KeyDown="TxtProductCode_KeyDown"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Name="BtnClearCode" Content="清除" Margin="0,5" Width="80"
                               Click="BtnClearCode_Click"/>
                    </StackPanel>
                    <CheckBox Name="ChkContinueDuplicate" Content="重复扫码自动继续" Margin="0,0,0,10"/>
                </StackPanel>

                <Separator Margin="0,10"/>

                <StackPanel>
                    <TextBlock Text="机型图片" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="4" Height="335">
                        <Image Name="ImgModelPreview" Stretch="Uniform" Margin="0,0,0,-2"/>
                    </Border>
                </StackPanel>

                <Separator Margin="0,10"/>

                <StackPanel>
                    <TextBlock Text="MES 控制" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Name="TxtMesStatus" Text="MES 状态：未启用" FontSize="14" Foreground="Red" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Name="BtnMesConnect" Content="启用" Width="110" Margin="0,0,10,0"
                                Click="BtnMesConnect_Click"/>
                        <Button Name="BtnMesDisconnect" Content="停用" Width="110"
                                Click="BtnMesDisconnect_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 中间测试区域 -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <StackPanel Orientation="Horizontal" Margin="20,0">
                    <Button Name="BtnStartLeft" Content="开始左通道" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartLeft_Click"/>
                    <Button Name="BtnStopLeft" Content="停止左通道" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="White" Click="BtnStopLeft_Click" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="20,0">
                    <Button Name="BtnStartRight" Content="开始右通道" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartRight_Click"/>
                    <Button Name="BtnStopRight" Content="停止右通道" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="White" Click="BtnStopRight_Click" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="6" Margin="0,0,10,0" Padding="10">
                    <StackPanel>
                        <Border Name="LeftStatusBanner" Background="#4C566A" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtLeftStatus" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="LeftStageList" ItemTemplate="{StaticResource StageTemplate}" Height="520"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="6" Margin="10,0,0,0" Padding="10">
                    <StackPanel>
                        <Border Name="RightStatusBanner" Background="#4C566A" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtRightStatus" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="RightStageList" ItemTemplate="{StaticResource StageTemplate}" Height="520"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#4C566A" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="0,0,15,0">
                        <TextBlock Name="TxtLeftCurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Rectangle Grid.Column="1" Width="1" Fill="#ECEFF4" Margin="10,0" RadiusX="0.5" RadiusY="0.5"/>
                    <Border Grid.Column="2" Padding="15,0,0,0">
                        <TextBlock Name="TxtRightCurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 右侧测试结果 -->
        <Border Grid.Column="2" Background="White" Margin="10" CornerRadius="5">
            <StackPanel Margin="15">
                <TextBlock Text="测试结果" FontSize="16" FontWeight="Bold"
                          Foreground="#2E3440" Margin="0,0,0,15"/>
                <ScrollViewer Height="800" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="TestResultPanel"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
