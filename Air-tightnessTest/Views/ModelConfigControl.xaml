<UserControl x:Class="LumbarMassageTest.UserControls.ModelConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:autoTest="clr-namespace:LumbarMassageTest.Views.AutoTest">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧型号列表 -->
        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="产品型号" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Name="BtnAddModel" Content="新增" Width="60" Margin="0,0,5,0"
                           Click="BtnAddModel_Click"/>
                    <Button Name="BtnDeleteModel" Content="删除" Width="60" Margin="5,0,0,0"
                           Click="BtnDeleteModel_Click"/>
                </StackPanel>

                <!-- 新增导入导出按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Name="BtnImportConfig" Content="导入配置" Width="80" Margin="0,0,5,0"
                           Click="BtnImportConfig_Click" Background="#FF0078D7" Foreground="White"/>
                    <Button Name="BtnExportConfig" Content="导出配置" Width="80" Margin="5,0,0,0"
                           Click="BtnExportConfig_Click" Background="#FF107C10" Foreground="White"/>
                </StackPanel>

                <ListBox Name="ModelListBox" Height="700"
                        SelectionChanged="ModelListBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- 右侧配置详情 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Margin="10" CornerRadius="5" Padding="20">
                <StackPanel Name="ConfigPanel">
                    <!-- 基本信息与流程配置合并为一行两列 -->
                    <GroupBox Header="基本信息与流程配置" Margin="0,0,0,20">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 基本信息列 (左侧) -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="型号名称:" VerticalAlignment="Center" Margin="5"/>
                                <TextBox Name="TxtModelName" Margin="5" Height="25"/>

                                <TextBlock Text="型号描述:" VerticalAlignment="Center" Margin="5,10,5,5"/>
                                <TextBox Name="TxtModelDesc" Margin="5" Height="25"/>

                                <TextBlock Text="型号图片:" VerticalAlignment="Center" Margin="5,10,5,5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBox Name="TxtImagePath" Width="200" Margin="0,0,10,0" Height="25"/>
                                    <Button Name="BtnSelectImage" Content="选择图片" Width="80" Height="25"
                       Click="BtnSelectImage_Click"/>
                                </StackPanel>

                                <Image Name="ModelImage" Height="120" Stretch="Uniform"
                  HorizontalAlignment="Left" Margin="5,10,5,5"/>
                            </StackPanel>

                            <!-- 流程配置列 (右侧) -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <CheckBox Name="ChkEnableBarcode" Content="启用扫码检查" Margin="5"/>
                                <CheckBox Name="ChkEnableCurrentMonitor" Content="启用电流监控" Margin="5"/>
                                <CheckBox Name="ChkRecordCurrentBeforeStart" Content="启动前记录电流" Margin="5"/>
                                <CheckBox Name="ChkEnableLumbarTest" Content="启用腰托测试" Margin="5"
                                          Checked="ChkEnableLumbarTest_Checked"
                                          Unchecked="ChkEnableLumbarTest_Checked"/>
                                <CheckBox Name="ChkEnableMassageTest" Content="启用按摩测试" Margin="5"/>
                                <CheckBox Name="ChkCheckSameModel" Content="主副驾同款检查" Margin="5"/>
                                <CheckBox Name="ChkPromptOnDuplicate" Content="重复扫码提示" Margin="5"/>
                                <CheckBox Name="ChkEnableBarcodePrefixCheck" Content="扫码前缀判断" Margin="5"/>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="扫码前缀内容:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Name="TxtBarcodePrefix" Width="120" Margin="10,0,0,0" Height="25"/>
                                </StackPanel>
                                <CheckBox Name="ChkMeasureSleepCurrent" Content="测量休眠电流" Margin="5"/>
                                <CheckBox Name="ChkMeasureStaticCurrent" Content="测量静态电流" Margin="5"/>

                                <StackPanel Orientation="Horizontal" Margin="5,10,5,5">
                                    <TextBlock Text="最大重测次数:" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Name="TxtMaxTestCount" Width="60" Margin="10,0,0,0" Height="25"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="主副驾断电(ms):" VerticalAlignment="Center" Width="100"/>
                                    <TextBox Name="TxtPowerOffDuration" Width="80" Margin="10,0,0,0" Height="25"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- 通道配置 -->
                    <StackPanel Margin="0,0,0,20">
                        <GroupBox Header="报文配置" Margin="0,0,0,15">
                            <StackPanel>
                                <TabControl>
                                    <TabItem Header="开机报文">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="开机报文预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="PowerOnMessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigPowerOnMessage_Click"/>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="休眠报文">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="休眠报文预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="SleepMessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigSleepMessage_Click"/>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="停止报文">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="停止报文预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="StopMessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigStopMessage_Click"/>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="按摩报文">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="按摩报文预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="MassageMessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigMassageMessage_Click"/>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="按摩报文2">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="按摩报文2预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="Massage2MessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigMassage2Message_Click"/>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="读取报文">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="读取报文预览:" Margin="0,0,0,5"/>
                                            <TextBlock Name="ReadMessagePreview" Text="未配置" TextWrapping="Wrap"
                                                       Background="#F3F4F6" Padding="6" FontFamily="Consolas"/>
                                            <Button Content="配置报文" Width="100" Margin="0,10,0,0"
                                                    Click="BtnConfigReadMessage_Click"/>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="按键报文测试配置（最多8项）" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Name="BtnAddMessageKeyTest" Content="添加按键项" Width="100" Margin="0,0,10,0"
                                                Click="BtnAddMessageKeyTest_Click"/>
                                        <Button Name="BtnRemoveMessageKeyTest" Content="删除按键项" Width="100"
                                                Click="BtnRemoveMessageKeyTest_Click"/>
                                    </StackPanel>
                                    <DataGrid Name="MessageKeyTestGrid" Height="220" AutoGenerateColumns="False" CanUserResizeColumns="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="序号" Binding="{Binding Order}" Width="60"/>
                                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="60"/>
                                            <DataGridTextColumn Header="通道1 0x输出寄存器" Binding="{Binding Ch1OutputRegisterAddress}" Width="140"/>
                                            <DataGridTextColumn Header="通道2 0x输出寄存器" Binding="{Binding Ch2OutputRegisterAddress}" Width="140"/>
                                            <DataGridTextColumn Header="通道3 0x输出寄存器" Binding="{Binding Ch3OutputRegisterAddress}" Width="140"/>
                                            <DataGridTextColumn Header="通道4 0x输出寄存器" Binding="{Binding Ch4OutputRegisterAddress}" Width="140"/>
                                            <DataGridTextColumn Header="读取字节序号(1起)" Binding="{Binding ReadByteIndex}" Width="120"/>
                                            <DataGridTextColumn Header="正确报文内容(0-255)" Binding="{Binding ExpectedValue}" Width="130"/>
                                            <DataGridComboBoxColumn Header="触发方式"
                                                                    SelectedValueBinding="{Binding TriggerMode}"
                                                                    SelectedValuePath="Value"
                                                                    DisplayMemberPath="Label"
                                                                    Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="电流与休眠参数(通道共用)" Margin="0,0,0,15">
                            <StackPanel Margin="10">
                                <TextBlock Text="通用参数" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="静态电流:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedStaticMin" Width="80" Height="25"/>
                                    <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBox Name="TxtSharedStaticMax" Width="80" Height="25"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="工作电流:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedWorkMin" Width="80" Height="25"/>
                                    <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBox Name="TxtSharedWorkMax" Width="80" Height="25"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="电流超限:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedCurrentOver" Width="80" Height="25"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="休眠阈值:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedSleepThreshold" Width="80" Height="25"/>
                                    <TextBlock Text="超时(ms):" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBox Name="TxtSharedSleepTimeout" Width="80" Height="25"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="编码值量程:" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedHeightCodeMin" Width="80" Height="25"/>
                                    <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBox Name="TxtSharedHeightCodeMax" Width="80" Height="25"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="高度量程(mm):" VerticalAlignment="Center" Width="90"/>
                                    <TextBox Name="TxtSharedHeightRangeMin" Width="80" Height="25"/>
                                    <TextBlock Text="~" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBox Name="TxtSharedHeightRangeMax" Width="80" Height="25"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="LumbarConfigGroup" Header="腰托动作配置" Margin="0,0,0,15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Name="BtnAddLumbar" Content="添加动作" Width="90" Margin="0,0,10,0"
                                            Click="BtnAddLumbar_Click"/>
                                    <Button Name="BtnRemoveLumbar" Content="删除动作" Width="90"
                                            Click="BtnRemoveLumbar_Click"/>
                                </StackPanel>
                                <DataGrid Name="LumbarConfigGrid" Height="220" AutoGenerateColumns="False" CanUserResizeColumns="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding Order}" Width="60"/>
                                        <DataGridComboBoxColumn Header="动作类型"
                                                                SelectedValueBinding="{Binding Action}"
                                                                Width="160"
                                                                SelectedValuePath="Value"
                                                                DisplayMemberPath="DisplayName">
                                            <DataGridComboBoxColumn.ElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource" Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=LumbarActionList}"/>
                                                </Style>
                                            </DataGridComboBoxColumn.ElementStyle>
                                            <DataGridComboBoxColumn.EditingElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource" Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=LumbarActionList}"/>
                                                </Style>
                                            </DataGridComboBoxColumn.EditingElementStyle>
                                        </DataGridComboBoxColumn>
                                        <DataGridTextColumn Header="目标高度(mm)" Binding="{Binding TargetHeight}" Width="120"/>
                                        <DataGridTextColumn Header="目标时间(ms)" Binding="{Binding TargetTime}" Width="120"/>
                                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="70"/>
                                        <DataGridTextColumn Header="通道1 0x地址" Binding="{Binding Ch1RegisterAddress}" Width="140"/>
                                        <DataGridTextColumn Header="通道2 0x地址" Binding="{Binding Ch2RegisterAddress}" Width="140"/>
                                        <DataGridTextColumn Header="通道3 0x地址" Binding="{Binding Ch3RegisterAddress}" Width="140"/>
                                        <DataGridTextColumn Header="通道4 0x地址" Binding="{Binding Ch4RegisterAddress}" Width="140"/>
                                        <DataGridTemplateColumn Header="发送报文" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="配置报文" Click="BtnConfigLumbarMessage_Click"
                                                            Tag="{Binding}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="手动调试点位配置" Margin="0,0,0,15">
                            <DataGrid x:Name="ManualControlGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeColumns="True"
                                      HeadersVisibility="Column"
                                      Height="420">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="项目" Binding="{Binding Label}" Width="180" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="类型" Binding="{Binding TypeLabel}" Width="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="通道1" Binding="{Binding Ch1Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="通道2" Binding="{Binding Ch2Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="通道3" Binding="{Binding Ch3Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="通道4" Binding="{Binding Ch4Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Header="按摩动作配置">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Name="BtnAddMassage" Content="添加动作" Width="90" Margin="0,0,10,0"
                                            Click="BtnAddMassage_Click"/>
                                    <Button Name="BtnRemoveMassage" Content="删除动作" Width="90"
                                            Click="BtnRemoveMassage_Click"/>
                                </StackPanel>
                                <autoTest:MassageTestView x:Name="MassageView"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- 保存按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                        <Button Name="BtnSaveModel" Content="保存配置" Width="100" Height="35"
                               Background="Green" Foreground="White" FontSize="14"
                               Click="BtnSaveModel_Click"/>
                        <Button Name="BtnReloadModel" Content="重新加载" Width="100" Height="35"
                               Background="Blue" Foreground="White" FontSize="14"
                               Margin="20,0,0,0" Click="BtnReloadModel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
