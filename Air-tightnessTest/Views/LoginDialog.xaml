<Window x:Class="LumbarMassageTest.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LumbarMassageTest.Views"
        mc:Ignorable="d"
        Title="LoginDialog" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="BluePrimary" Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueDark" Color="#1E40AF"/>
        <SolidColorBrush x:Key="BlueLight" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="BlueBorder" Color="#C7D2FE"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
    </Window.Resources>

    <Grid Background="{StaticResource BlueLight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="上海舒井气袋气密性检测系统"
                   FontSize="36" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,20,0,10"
                   Foreground="{StaticResource BlueDark}"/>
        <!-- 登录表单 -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Margin="40,20" Padding="30"
                BorderBrush="{StaticResource BlueBorder}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="用户名:" FontSize="14" Margin="0,0,0,5"
                           Foreground="{StaticResource TextPrimary}"/>
                <ComboBox Grid.Row="1" Name="CmbUsername" FontSize="14" Padding="5"
                          Margin="0,0,0,15" IsEditable="True" IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True" SelectionChanged="CmbUsername_SelectionChanged"
                          LostFocus="CmbUsername_LostFocus"
                          Background="#F8FAFF" BorderBrush="{StaticResource BlueBorder}"
                          Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Grid.Row="2" Text="密码:" FontSize="14" Margin="0,0,0,5"
                           Foreground="{StaticResource TextPrimary}"/>
                <PasswordBox Grid.Row="3" Name="TxtPassword" FontSize="14" Padding="5"
                            Margin="0,0,0,15" Background="#F8FAFF"
                            BorderBrush="{StaticResource BlueBorder}"
                            Foreground="{StaticResource TextPrimary}"/>
                <CheckBox Grid.Row="4" Name="ChkRememberPassword" Content="记住密码"
                          FontSize="13" Foreground="{StaticResource TextPrimary}"/>
            </Grid>
        </Border>
        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Name="BtnLogin" Content="登录" Width="80" Height="35"
                    Margin="10,0" Click="BtnLogin_Click"
                    Background="{StaticResource BluePrimary}" Foreground="White"
                    BorderThickness="0" FontSize="18"/>
            <Button Name="BtnCancel" Content="取消" Width="80" Height="35"
                    Margin="10,0" Click="BtnCancel_Click"
                    Background="#E0E7FF" Foreground="{StaticResource BlueDark}"
                    BorderBrush="{StaticResource BlueBorder}" BorderThickness="1"
                    FontSize="18"/>
        </StackPanel>
    </Grid>
</Window>
