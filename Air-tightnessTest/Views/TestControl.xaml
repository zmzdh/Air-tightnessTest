<UserControl x:Class="LumbarMassageTest.UserControls.TestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TestButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <DataTemplate x:Key="StageTemplate">
            <Border Margin="4" Padding="8" CornerRadius="6" Background="{Binding StateBackground}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="{Binding IndicatorBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StateDescription}" FontSize="12" Margin="10,0,0,0" Foreground="{Binding StateForeground}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MassagePointTemplate">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,6">
                <Ellipse Width="18" Height="18" Fill="{Binding IndicatorBrush}" Stroke="{Binding IndicatorStroke}" StrokeThickness="1"/>
                <TextBlock Text="{Binding Index}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧工单信息 -->
        <Border Grid.Column="0" Margin="10" Style="{StaticResource CardBorderStyle}">
            <StackPanel Margin="15">
                <TextBlock Text="工单与扫码" Style="{StaticResource SectionTitleStyle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="工单号:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TxtWorkOrder" Margin="5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="产品型号:" Style="{StaticResource InfoLabelStyle}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Name="CmbProductModel" Margin="5"
                             SelectionChanged="CmbProductModel_SelectionChanged" DisplayMemberPath="ModelName"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="操作员:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Name="TxtOperator" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="目标产量:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Name="TxtTargetProduction" Margin="5"
                             PreviewTextInput="TxtTargetProduction_PreviewTextInput"
                             LostFocus="TxtTargetProduction_LostFocus"
                             KeyDown="TxtTargetProduction_KeyDown"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="测试次数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Name="TxtTestCount" Text="0" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="合格数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Name="TxtPassCount" Text="0" Style="{StaticResource InfoValueStyle}" Foreground="Green"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="不合格数:" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Name="TxtFailCount" Text="0" Style="{StaticResource InfoValueStyle}" Foreground="Red"/>

                    <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Height="12" Margin="5,6,5,0"
                            Background="White" BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1"
                            CornerRadius="6">
                        <ProgressBar Name="OverallProductionProgress" Height="10" Margin="1"
                                     Foreground="{StaticResource BrandBlueBrush}" Background="White"/>
                    </Border>
                </Grid>

                <Separator Margin="0,15"/>

                <StackPanel>
                    <TextBlock Text="产品扫码" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox Name="TxtProductCode" FontSize="16" Padding="5" Margin="0,0,0,5"
                            InputMethod.IsInputMethodEnabled="False"
                            PreviewKeyDown="TxtProductCode_PreviewKeyDown"
                            PreviewTextInput="TxtProductCode_PreviewTextInput"
                            KeyDown="TxtProductCode_KeyDown"/>
                    <StackPanel Orientation="Horizontal">
                    <Button Name="BtnClearCode" Content="清除" Margin="0,5" Width="80"
                               Style="{StaticResource SoftButtonStyle}" Click="BtnClearCode_Click"/>
                    </StackPanel>
                    <CheckBox Name="ChkContinueDuplicate" Content="重复扫码自动继续" Margin="0,0,0,10"
                              Checked="ChkContinueDuplicate_CheckedChanged"
                              Unchecked="ChkContinueDuplicate_CheckedChanged"/>
                </StackPanel>

                <Separator Margin="0,10"/>

                <StackPanel Name="ModelImageSection">
                    <TextBlock Text="机型图片" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1" CornerRadius="6" Height="420">
                        <Image Name="ImgModelPreview" Stretch="Uniform" Margin="0,0,0,-2"/>
                    </Border>
                </StackPanel>

                <Separator Margin="0,10"/>

                <StackPanel>
                    <TextBlock Text="MES 控制" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Name="TxtMesStatus" Text="MES 状态：未启用" FontSize="14" Foreground="Red" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                    <Button Name="BtnMesConnect" Content="启用" Width="110" Margin="0,0,10,0"
                                Style="{StaticResource SoftButtonStyle}"
                                Click="BtnMesConnect_Click"/>
                    <Button Name="BtnMesDisconnect" Content="停用" Width="110"
                                Style="{StaticResource SoftButtonStyle}"
                                Click="BtnMesDisconnect_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 中间测试区域 -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="ChannelActionGrid" Grid.Row="0" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="BtnStartLeft" Content="启动通道1" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartLeft_Click"/>
                    <Button Name="BtnStopLeft" Content="停止通道1" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="Black" Click="BtnStopLeft_Click" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="BtnStartRight" Content="启动通道2" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartRight_Click"/>
                    <Button Name="BtnStopRight" Content="停止通道2" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="Black" Click="BtnStopRight_Click" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="BtnStartCh3" Content="启动通道3" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartCh3_Click"/>
                    <Button Name="BtnStopCh3" Content="停止通道3" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="Black" Click="BtnStopCh3_Click" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="BtnStartCh4" Content="启动通道4" Style="{StaticResource TestButtonStyle}"
                            Background="Green" Foreground="White" Click="BtnStartCh4_Click"/>
                    <Button Name="BtnStopCh4" Content="停止通道4" Style="{StaticResource TestButtonStyle}"
                            Background="Red" Foreground="Black" Click="BtnStopCh4_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="ChannelStatusGrid" Grid.Row="1" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Border Name="LeftStatusBanner" Background="{StaticResource BrandBlueDarkBrush}" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtLeftStatus" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="LeftStageList" ItemTemplate="{StaticResource StageTemplate}" Height="700"
                                 BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Border Name="RightStatusBanner" Background="{StaticResource BrandBlueDarkBrush}" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtRightStatus" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="RightStageList" ItemTemplate="{StaticResource StageTemplate}" Height="700"
                                 BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Border Name="Ch3StatusBanner" Background="{StaticResource BrandBlueDarkBrush}" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtCh3Status" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="Ch3StageList" ItemTemplate="{StaticResource StageTemplate}" Height="700"
                                 BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Margin="0,0,0,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Border Name="Ch4StatusBanner" Background="{StaticResource BrandBlueDarkBrush}" CornerRadius="6" Padding="20" Margin="0,0,0,10">
                            <TextBlock Name="TxtCh4Status" Text="等待测试" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </Border>
                        <ListBox Name="Ch4StageList" ItemTemplate="{StaticResource StageTemplate}" Height="700"
                                 BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ChannelSummaryGrid" Grid.Row="2" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道1 产量/时间" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch1ElapsedPanel" Margin="0,6,0,0" Visibility="Collapsed">
                            <TextBlock Name="Ch1ElapsedText" Text="当前测试已进行 0分00秒" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Name="Ch1CountPanel" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="测试次数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch1TestCount" FontSize="12" FontWeight="Bold" Text="0" Margin="0,0,12,0"/>
                                <TextBlock Text="合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch1PassCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Green" Margin="0,0,12,0"/>
                                <TextBlock Text="不合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch1FailCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Red"/>
                            </StackPanel>
                            <Border Background="#EEF2F6" Height="10" Margin="0,6,0,0" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="Ch1PassBarColumn" Width="0*"/>
                                        <ColumnDefinition x:Name="Ch1FailBarColumn" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="Green" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Grid.Column="1" Fill="Red" RadiusX="5" RadiusY="5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道2 产量/时间" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch2ElapsedPanel" Margin="0,6,0,0" Visibility="Collapsed">
                            <TextBlock Name="Ch2ElapsedText" Text="当前测试已进行 0分00秒" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Name="Ch2CountPanel" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="测试次数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch2TestCount" FontSize="12" FontWeight="Bold" Text="0" Margin="0,0,12,0"/>
                                <TextBlock Text="合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch2PassCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Green" Margin="0,0,12,0"/>
                                <TextBlock Text="不合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch2FailCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Red"/>
                            </StackPanel>
                            <Border Background="#EEF2F6" Height="10" Margin="0,6,0,0" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="Ch2PassBarColumn" Width="0*"/>
                                        <ColumnDefinition x:Name="Ch2FailBarColumn" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="Green" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Grid.Column="1" Fill="Red" RadiusX="5" RadiusY="5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道3 产量/时间" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch3ElapsedPanel" Margin="0,6,0,0" Visibility="Collapsed">
                            <TextBlock Name="Ch3ElapsedText" Text="当前测试已进行 0分00秒" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Name="Ch3CountPanel" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="测试次数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch3TestCount" FontSize="12" FontWeight="Bold" Text="0" Margin="0,0,12,0"/>
                                <TextBlock Text="合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch3PassCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Green" Margin="0,0,12,0"/>
                                <TextBlock Text="不合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch3FailCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Red"/>
                            </StackPanel>
                            <Border Background="#EEF2F6" Height="10" Margin="0,6,0,0" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="Ch3PassBarColumn" Width="0*"/>
                                        <ColumnDefinition x:Name="Ch3FailBarColumn" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="Green" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Grid.Column="1" Fill="Red" RadiusX="5" RadiusY="5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Margin="0,0,0,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道4 产量/时间" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch4ElapsedPanel" Margin="0,6,0,0" Visibility="Collapsed">
                            <TextBlock Name="Ch4ElapsedText" Text="当前测试已进行 0分00秒" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Name="Ch4CountPanel" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="测试次数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch4TestCount" FontSize="12" FontWeight="Bold" Text="0" Margin="0,0,12,0"/>
                                <TextBlock Text="合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch4PassCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Green" Margin="0,0,12,0"/>
                                <TextBlock Text="不合格数:" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Name="Ch4FailCount" FontSize="12" FontWeight="Bold" Text="0" Foreground="Red"/>
                            </StackPanel>
                            <Border Background="#EEF2F6" Height="10" Margin="0,6,0,0" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="Ch4PassBarColumn" Width="0*"/>
                                        <ColumnDefinition x:Name="Ch4FailBarColumn" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="Green" RadiusX="5" RadiusY="5"/>
                                    <Rectangle Grid.Column="1" Fill="Red" RadiusX="5" RadiusY="5"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ChannelGraphicGrid" Grid.Row="3" Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道1 状态图形" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch1LumbarPanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="腰托高度 (满量程 50mm)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="50mm" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0mm" FontSize="11" HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                </StackPanel>
                                <ProgressBar Grid.Column="1" Name="Ch1LumbarBar" Width="28" Height="140" Maximum="50"
                                             Value="0" Orientation="Vertical" Margin="8,0"/>
                                <TextBlock Grid.Column="2" Name="Ch1LumbarValue" Text="0.0 mm"
                                           VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Name="Ch1MassagePanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="按摩开关状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl Name="Ch1MassagePoints" ItemTemplate="{StaticResource MassagePointTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8" Rows="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                        <TextBlock Name="Ch1GraphicPlaceholder" Text="等待测试状态图形" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道2 状态图形" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch2LumbarPanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="腰托高度 (满量程 50mm)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="50mm" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0mm" FontSize="11" HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                </StackPanel>
                                <ProgressBar Grid.Column="1" Name="Ch2LumbarBar" Width="28" Height="140" Maximum="50"
                                             Value="0" Orientation="Vertical" Margin="8,0"/>
                                <TextBlock Grid.Column="2" Name="Ch2LumbarValue" Text="0.0 mm"
                                           VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Name="Ch2MassagePanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="按摩开关状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl Name="Ch2MassagePoints" ItemTemplate="{StaticResource MassagePointTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8" Rows="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                        <TextBlock Name="Ch2GraphicPlaceholder" Text="等待测试状态图形" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Margin="0,0,10,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道3 状态图形" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch3LumbarPanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="腰托高度 (满量程 50mm)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="50mm" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0mm" FontSize="11" HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                </StackPanel>
                                <ProgressBar Grid.Column="1" Name="Ch3LumbarBar" Width="28" Height="140" Maximum="50"
                                             Value="0" Orientation="Vertical" Margin="8,0"/>
                                <TextBlock Grid.Column="2" Name="Ch3LumbarValue" Text="0.0 mm"
                                           VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Name="Ch3MassagePanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="按摩开关状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl Name="Ch3MassagePoints" ItemTemplate="{StaticResource MassagePointTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8" Rows="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                        <TextBlock Name="Ch3GraphicPlaceholder" Text="等待测试状态图形" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Margin="0,0,0,0" Padding="10" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通道4 状态图形" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Name="Ch4LumbarPanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="腰托高度 (满量程 50mm)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="50mm" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Text="0mm" FontSize="11" HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                </StackPanel>
                                <ProgressBar Grid.Column="1" Name="Ch4LumbarBar" Width="28" Height="140" Maximum="50"
                                             Value="0" Orientation="Vertical" Margin="8,0"/>
                                <TextBlock Grid.Column="2" Name="Ch4LumbarValue" Text="0.0 mm"
                                           VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Name="Ch4MassagePanel" Margin="0,8,0,6" Visibility="Collapsed">
                            <TextBlock Text="按摩开关状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl Name="Ch4MassagePoints" ItemTemplate="{StaticResource MassagePointTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8" Rows="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                        <TextBlock Name="Ch4GraphicPlaceholder" Text="等待测试状态图形" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Background="{StaticResource BrandBlueDarkBrush}" CornerRadius="6" Padding="10">
                <Grid x:Name="ChannelStepGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="0,0,15,0">
                        <TextBlock Name="TxtLeftCurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource SurfaceBlueBrush}" Margin="10,0" RadiusX="0.5" RadiusY="0.5"/>
                    <Border Grid.Column="2" Padding="15,0">
                        <TextBlock Name="TxtRightCurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource SurfaceBlueBrush}" Margin="10,0" RadiusX="0.5" RadiusY="0.5"/>
                    <Border Grid.Column="4" Padding="15,0">
                        <TextBlock Name="TxtCh3CurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Rectangle Grid.Column="5" Width="1" Fill="{StaticResource SurfaceBlueBrush}" Margin="10,0" RadiusX="0.5" RadiusY="0.5"/>
                    <Border Grid.Column="6" Padding="15,0,0,0">
                        <TextBlock Name="TxtCh4CurrentStep" Text="等待开始测试" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 右侧测试结果 -->
        <Border Grid.Column="2" Margin="10" Style="{StaticResource CardBorderStyle}">
            <StackPanel Margin="15">
                <TextBlock Text="测试结果" Style="{StaticResource SectionTitleStyle}"/>
                <ScrollViewer Height="1000" VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="TestResultPanel"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
