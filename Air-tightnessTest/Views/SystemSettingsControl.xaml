<UserControl x:Class="LumbarMassageTest.UserControls.SystemSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="1440"
             d:DesignWidth="3440"
             Background="#ECEFF4">
    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,20">
            <TextBlock Text="系统设置" FontSize="28" FontWeight="Bold" Foreground="#2E3440" />
            <TextBlock Text="（仅管理员可操作）" FontSize="16" Foreground="#4C566A" Margin="20,8,0,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Modbus TCP 服务" FontSize="20" Grid.Row="0" Grid.Column="0" Margin="0,0,20,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="PLC IP地址" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPlcIp" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="端口号" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPlcPort" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="离散输入数量" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPlcInputCount" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="线圈读取数量" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPlcCoilCount" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />
                </Grid>
            </GroupBox>

            <GroupBox Header="MES 系统" FontSize="20" Grid.Row="0" Grid.Column="1" Margin="20,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="对接模式" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbMesMode" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesIp" Text="MES IP地址" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtMesIp" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesPort" Text="端口号" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtMesPort" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblMesProtocol" Text="通信协议" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbMesProtocol" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblModbusIp" Text="Modbus绑定地址" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusIp" Grid.Row="8" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="LblModbusPort" Text="Modbus端口" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtModbusPort" Grid.Row="10" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock x:Name="TxtMesStatus" Grid.Row="12" Grid.ColumnSpan="2" FontSize="16" Foreground="Red" Text="MES 状态：未启用" />

                    <StackPanel x:Name="HttpButtonPanel" Grid.Row="14" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnMesConnect" Content="启用" Width="100" Height="36" FontSize="16" Click="BtnMesConnect_Click" Margin="0,0,12,0" />
                        <Button x:Name="BtnMesDisconnect" Content="停用" Width="100" Height="36" FontSize="16" Click="BtnMesDisconnect_Click" IsEnabled="False" Margin="0,0,12,0" />
                        <Button x:Name="BtnMesSimulatePush" Content="模拟推送" Width="120" Height="36" FontSize="16" Click="BtnMesSimulatePush_Click" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="串口配置" FontSize="20" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,20,0,0">
                <UniformGrid Columns="1" Margin="20">
                    <StackPanel Margin="0,0,20,0" Visibility="Collapsed">
                        <TextBlock Text="设备1（报文通讯）" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="端口号" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial1Port" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="波特率" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial1Baud" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="数据位" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial1DataBits" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="校验位" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <ComboBox x:Name="CmbSerial1Parity" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="停止位" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <ComboBox x:Name="CmbSerial1StopBits" Grid.Row="8" Grid.Column="1" Height="36" FontSize="16" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="20,0,0,0">
                        <TextBlock Text="设备2（模拟量IO模块）" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="端口号" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial2Port" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="波特率" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial2Baud" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="数据位" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <TextBox x:Name="TxtSerial2DataBits" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="校验位" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <ComboBox x:Name="CmbSerial2Parity" Grid.Row="6" Grid.Column="1" Height="36" FontSize="16" />
                            <TextBlock Text="停止位" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                            <ComboBox x:Name="CmbSerial2StopBits" Grid.Row="8" Grid.Column="1" Height="36" FontSize="16" />
                        </Grid>
                    </StackPanel>
                </UniformGrid>
            </GroupBox>

            <GroupBox Header="授权管理" FontSize="20" Grid.Row="4" Grid.Column="0" Margin="0,20,20,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="20">
                    <TextBlock x:Name="TxtLicenseStatus" FontSize="16" Margin="0,0,0,12" Foreground="#1F2937" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnExportRequest" Content="导出request.dat" Width="180" Height="40" FontSize="16" Click="BtnExportRequest_Click" Margin="0,0,12,0" />
                        <Button x:Name="BtnImportLicense" Content="导入license.lic" Width="180" Height="40" FontSize="16" Click="BtnImportLicense_Click" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="全局配置" FontSize="20" Grid.Row="4" Grid.Column="1" Margin="20,20,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="通道数量" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <ComboBox x:Name="CmbChannelCount" Grid.Row="0" Grid.Column="1" Height="36" FontSize="16" />

                    <TextBlock Text="输入量程KPa" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPressureInputFullScale" Grid.Row="2" Grid.Column="1" Height="36" FontSize="16" />
                    <TextBlock Text="50-200" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" FontSize="14" Foreground="#4C566A" />

                    <TextBlock Text="输出量程KPa" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontSize="16" />
                    <TextBox x:Name="TxtPressureOutputFullScale" Grid.Row="4" Grid.Column="1" Height="36" FontSize="16" />
                    <TextBlock Text="100-200" Grid.Row="4" Grid.Column="3" VerticalAlignment="Center" FontSize="14" Foreground="#4C566A" />

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnSaveConfig" Content="保存配置" Width="120" Height="36" FontSize="16" Click="BtnSaveConfig_Click" Margin="0,0,12,0" />
                        <Button x:Name="BtnReloadConfig" Content="重新加载" Width="120" Height="36" FontSize="16" Click="BtnReloadConfig_Click" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
