<UserControl x:Class="LumbarMassageTest.UserControls.ReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#2E3440"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 查询条件 -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="开始日期:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker Grid.Row="0" Grid.Column="1" Name="StartDatePicker" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="结束日期:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker Grid.Row="0" Grid.Column="3" Name="EndDatePicker" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="产品型号:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="5" Name="CmbProductModel" Margin="5"
                          DisplayMemberPath="Display" SelectedValuePath="Value"/>

                <TextBlock Grid.Row="0" Grid.Column="6" Text="操作员:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="7" Name="CmbOperator" Margin="5"
                          DisplayMemberPath="Display" SelectedValuePath="Value"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="测试结果:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Name="CmbTestResult" Margin="5">
                    <ComboBoxItem Content="全部" Tag=""/>
                    <ComboBoxItem Content="合格" Tag="Pass"/>
                    <ComboBoxItem Content="不合格" Tag="Fail"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="工单号:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="3" Name="TxtWorkOrder" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="产品代码:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="5" Name="TxtProductCode" Margin="5"/>

                <Button Grid.Row="1" Grid.Column="6" Name="BtnQuery" Content="查询" Width="70" Margin="5"
                       Background="#5E81AC" Foreground="White" Click="BtnQuery_Click"/>
                <Button Grid.Row="1" Grid.Column="7" Name="BtnExport" Content="导出" Width="70" Margin="5"
                       Background="#A3BE8C" Foreground="White" Click="BtnExport_Click"/>
            </Grid>
        </Border>

        <!-- 统计卡片 -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,10">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Name="TxtTotalCount" Text="0" Style="{StaticResource StatNumberStyle}" Foreground="#3B82F6"/>
                    <TextBlock Text="总测试数" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Name="TxtPassCount" Text="0" Style="{StaticResource StatNumberStyle}" Foreground="#10B981"/>
                    <TextBlock Text="合格数" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Name="TxtFailCount" Text="0" Style="{StaticResource StatNumberStyle}" Foreground="#EF4444"/>
                    <TextBlock Text="不合格数" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Name="TxtPassRate" Text="0%" Style="{StaticResource StatNumberStyle}" Foreground="#8B5CF6"/>
                    <TextBlock Text="合格率" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Name="TxtAvgTestTime" Text="0s" Style="{StaticResource StatNumberStyle}" Foreground="#F59E0B"/>
                    <TextBlock Text="平均测试时长" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 详细数据 -->
        <TabControl Grid.Row="2">
            <TabItem Header="测试记录">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" Name="TestRecordsGrid" AutoGenerateColumns="False"
                             CanUserAddRows="False" CanUserDeleteRows="False"
                             IsReadOnly="True" GridLinesVisibility="Horizontal"
                             AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="测试时间" Binding="{Binding TestTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="140"/>
                            <DataGridTextColumn Header="工单号" Binding="{Binding WorkOrder}" Width="120"/>
                            <DataGridTextColumn Header="产品型号" Binding="{Binding ProductModel}" Width="100"/>
                            <DataGridTextColumn Header="产品代码" Binding="{Binding ProductCode}" Width="150"/>
                            <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60"/>
                            <DataGridTextColumn Header="测试结果" Binding="{Binding Result}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Result}" Value="Pass">
                                                <Setter Property="Foreground" Value="Green"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Result}" Value="Fail">
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="失败原因" Binding="{Binding FailReason}" Width="200"/>
                            <DataGridTextColumn Header="操作员" Binding="{Binding Operator}" Width="80"/>
                            <DataGridTextColumn Header="测试时长(s)" Binding="{Binding TestDuration, StringFormat=F1}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <Button Name="BtnFirstPage" Content="首页" Click="BtnFirstPage_Click" Margin="5"/>
                        <Button Name="BtnPrevPage" Content="上一页" Click="BtnPrevPage_Click" Margin="5"/>
                        <TextBlock Name="TxtPageInfo" Text="第 1 页 / 共 1 页" VerticalAlignment="Center" Margin="10"/>
                        <Button Name="BtnNextPage" Content="下一页" Click="BtnNextPage_Click" Margin="5"/>
                        <Button Name="BtnLastPage" Content="末页" Click="BtnLastPage_Click" Margin="5"/>
                        <ComboBox Name="CmbPageSize" Width="80" Margin="10,0" SelectionChanged="CmbPageSize_SelectionChanged">
                            <ComboBoxItem Content="50" Tag="50"/>
                            <ComboBoxItem Content="100" Tag="100" IsSelected="True"/>
                            <ComboBoxItem Content="200" Tag="200"/>
                            <ComboBoxItem Content="500" Tag="500"/>
                        </ComboBox>
                        <TextBlock Text="条/页" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="统计分析">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 按日期统计 -->
                    <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="按日期统计" Style="{StaticResource SectionTitleStyle}"/>
                            <DataGrid Name="DateStatGrid" Height="400" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="总数" Binding="{Binding TotalCount}" Width="60"/>
                                    <DataGridTextColumn Header="合格" Binding="{Binding PassCount}" Width="60"/>
                                    <DataGridTextColumn Header="不合格" Binding="{Binding FailCount}" Width="60"/>
                                    <DataGridTextColumn Header="合格率" Binding="{Binding PassRate, StringFormat=P1}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- 按型号统计 -->
                    <Border Grid.Column="1" Background="White" CornerRadius="5" Margin="5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="按型号统计" Style="{StaticResource SectionTitleStyle}"/>
                            <DataGrid Name="ModelStatGrid" Height="400" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="产品型号" Binding="{Binding ProductModel}" Width="120"/>
                                    <DataGridTextColumn Header="总数" Binding="{Binding TotalCount}" Width="60"/>
                                    <DataGridTextColumn Header="合格" Binding="{Binding PassCount}" Width="60"/>
                                    <DataGridTextColumn Header="不合格" Binding="{Binding FailCount}" Width="60"/>
                                    <DataGridTextColumn Header="合格率" Binding="{Binding PassRate, StringFormat=P1}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="失效分析">
                <Border Background="White" CornerRadius="5" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="失效原因统计" Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid Name="FailReasonGrid" Height="500" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="失效原因" Binding="{Binding FailReason}" Width="300"/>
                                <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="80"/>
                                <DataGridTextColumn Header="占比" Binding="{Binding Percentage, StringFormat=P1}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

