                <StackPanel>
                    <TextBlock Text="485通讯测试" Style="{StaticResource SectionTitleStyle}"/>

                    <!-- 485通讯发送区域 -->
                    <GroupBox Header="发送区" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="发送数据区 (20字节):" Margin="0,5"/>
                            <TextBox Name="TxtSendData" Height="80" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     Text="3A 01 22 00 00 00 02 08 00 00 00 00 00 00 00 00 00 00 0D 0A"
                                     TextChanged="TxtSendData_TextChanged"
                                     LostKeyboardFocus="TxtSendData_LostKeyboardFocus"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Button Name="BtnSingleSend" Content="单次发送"
                                        Style="{StaticResource ControlButtonStyle}"
                                        Background="Green" Foreground="White"
                                        Click="BtnSingleSend_Click"/>
                                <Button Name="BtnContinuousSend" Content="连续发送"
                                        Style="{StaticResource ControlButtonStyle}"
                                        Background="Orange" Foreground="White"
                                        Click="BtnContinuousSend_Click"/>
                                <Button Name="BtnStopContinuous" Content="停止连发"
                                        Style="{StaticResource ControlButtonStyle}"
                                        Background="Red" Foreground="White"
                                        Click="BtnStopContinuous_Click"/>
                                <Button Name="BtnClearSend" Content="清除"
                                        Style="{StaticResource ControlButtonStyle}"
                                        Click="BtnClearSend_Click"/>
                            </StackPanel>
