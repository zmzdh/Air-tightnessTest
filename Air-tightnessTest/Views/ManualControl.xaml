                                     Text="00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 通讯日志区域 -->
                    <GroupBox Header="通讯日志">
                        <StackPanel>
                            <TextBox Name="TxtCommLog" Height="120" TextWrapping="Wrap" 
                        IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                        Background="#F0F0F0"/>

                            <Button Name="BtnClearLog" Content="清除日志" Margin="0,10"
                       Style="{StaticResource ControlButtonStyle}"
                       Click="BtnClearLog_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
