<UserControl x:Class="LumbarMassageTest.UserControls.ManualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1440" d:DesignWidth="3440">

    <UserControl.Resources>
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ChannelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col1" Width="*"/>
                <ColumnDefinition x:Name="Col2" Width="*"/>
                <ColumnDefinition x:Name="Col3" Width="*"/>
                <ColumnDefinition x:Name="Col4" Width="*"/>
                <ColumnDefinition x:Name="Col5" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：通道1控制 -->
            <Border x:Name="Ch1ControlPanel" Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="5" Margin="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="通道1控制" Style="{StaticResource ChannelTitleStyle}"/>

                    <!-- 按钮状态显示 -->
                    <GroupBox Header="按钮状态" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="停止按钮:" Margin="5"/>
                            <Ellipse Grid.Row="0" Grid.Column="1" Name="Ch1StopButtonIndicator" 
                                    Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="全测启动按钮:" Margin="5"/>
                            <Ellipse Grid.Row="1" Grid.Column="1" Name="Ch1FullTestButtonIndicator" 
                                    Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="按摩启动按钮:" Margin="5"/>
                            <Ellipse Grid.Row="2" Grid.Column="1" Name="Ch1MassageButtonIndicator" 
                                    Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="侧翼启动按钮:" Margin="5"/>
                            <Ellipse Grid.Row="3" Grid.Column="1" Name="Ch1SideWingButtonIndicator" 
                                    Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                        </Grid>
                    </GroupBox>

                    <!-- 输出控制 -->
                    <GroupBox Header="输出控制" Margin="0,0,0,15">
                        <UniformGrid Columns="3" Margin="0,5" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1PowerOff" Content="电源关闭"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1PowerOff_Click"/>
                                <Ellipse Name="Ch1PowerOffIndicator"
                                         Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1CylinderOpen" Content="夹紧气缸"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1CylinderOpen_Click"/>
                                <Ellipse Name="Ch1CylinderOpenIndicator"
                                         Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1CylinderClose" Content="备用气缸"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1CylinderClose_Click"/>
                                <Ellipse Name="Ch1CylinderCloseIndicator"
                                         Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1DriverSwitch" Content="主副驾切换"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1DriverSwitch_Click"/>
                                <Ellipse Name="Ch1DriverSwitchIndicator"
                                         Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>

                    <!-- 按键模拟 -->
                    <GroupBox Header="按键模拟" Margin="0,0,0,15">
                        <UniformGrid Columns="3" Margin="0,5" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1UpInflateDownDeflate" Content="上充下放"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1UpInflateDownDeflate_Click"/>
                                <Ellipse Name="Ch1UpInflateDownDeflateIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1DownInflateUpDeflate" Content="下充上放"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1DownInflateUpDeflate_Click"/>
                                <Ellipse Name="Ch1DownInflateUpDeflateIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1BothInflate" Content="上下同充"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1BothInflate_Click"/>
                                <Ellipse Name="Ch1BothInflateIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1BothDeflate" Content="上下同放"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1BothDeflate_Click"/>
                                <Ellipse Name="Ch1BothDeflateIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1MassageKey" Content="按摩开关"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1MassageKey_Click"/>
                                <Ellipse Name="Ch1MassageKeyIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>

                    <!-- 指示灯控制 -->
                    <GroupBox Header="指示灯控制" Margin="0,0,0,15">
                        <UniformGrid Columns="3" Margin="0,5" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1FullTestLight" Content="全测按钮灯"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1FullTestLight_Click"/>
                                <Ellipse Name="Ch1FullTestLightIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1SideWingLight" Content="侧翼按钮灯"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1SideWingLight_Click"/>
                                <Ellipse Name="Ch1SideWingLightIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1MassageLight" Content="按摩按钮灯"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1MassageLight_Click"/>
                                <Ellipse Name="Ch1MassageLightIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1OKLight" Content="测试OK灯"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1OKLight_Click"/>
                                <Ellipse Name="Ch1OKLightIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                                <Button Name="Ch1NGLight" Content="测试NG灯"
                                       Style="{StaticResource ToggleButtonStyle}"
                                       Click="Ch1NGLight_Click"/>
                                <Ellipse Name="Ch1NGLightIndicator" Style="{StaticResource StatusIndicatorStyle}" Fill="Gray"/>
                            </StackPanel>
                        </UniformGrid>
                    </GroupBox>

                    <!-- 测量值显示 -->
                    <GroupBox Header="测量值" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <TextBlock Text="编码器值:" VerticalAlignment="Center" Margin="5"/>
                            <TextBlock Name="TxtCh1Encoder" Text="0" 
                                      FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                            <TextBlock Text="高度值:" VerticalAlignment="Center" Margin="5"/>
                            <TextBlock Name="TxtCh1Height" Text="0 mm" 
                                      FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                            <TextBlock Text="电流值:" VerticalAlignment="Center" Margin="5"/>
                            <TextBlock Name="TxtCh1Current" Text="0 mA" 
                                      FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 按摩状态显示 -->
                    <GroupBox Header="按摩状态监控">
                        <ScrollViewer Height="260" VerticalScrollBarVisibility="Auto">
                            <StackPanel Name="Ch1MassageStatusPanel">
                                <!-- 动态添加按摩点状态 -->
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </StackPanel>
            </Border>

