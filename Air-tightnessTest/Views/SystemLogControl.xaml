<UserControl x:Class="LumbarMassageTest.UserControls.SystemLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BluePrimary" Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueDark" Color="#1E40AF"/>
        <SolidColorBrush x:Key="BlueLight" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="BlueBorder" Color="#C7D2FE"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BluePrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BlueBorder}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BlueLight}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="系统日志" FontSize="24" FontWeight="Bold" Margin="0,0,20,0"
                       Foreground="{StaticResource BlueDark}"/>
            <Button Content="刷新" Width="100" Height="32" Margin="0,0,10,0" Click="RefreshButton_Click" />
            <Button Content="清空显示" Width="100" Height="32" Click="ClearButton_Click" />
            <TextBlock Text="仅显示" Margin="30,0,10,0" VerticalAlignment="Center"
                       Foreground="{StaticResource TextPrimary}"/>
            <ComboBox Width="150" SelectedIndex="0" VerticalAlignment="Center" SelectionChanged="LevelFilter_SelectionChanged" x:Name="LevelFilter">
                <ComboBoxItem Content="全部" Tag="All" IsSelected="True" />
                <ComboBoxItem Content="信息" Tag="Info" />
                <ComboBoxItem Content="警告" Tag="Warning" />
                <ComboBoxItem Content="错误" Tag="Error" />
            </ComboBox>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10"
                BorderBrush="{StaticResource BlueBorder}" BorderThickness="1">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2" Padding="8" Background="#F8FAFF" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" >
                                    <TextBlock Text="[" Foreground="#5B6B8A" />
                                    <TextBlock Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Foreground="#5B6B8A" />
                                    <TextBlock Text="]" Foreground="#5B6B8A" Margin="2,0" />
                                    <TextBlock Text="[" Foreground="#5B6B8A" />
                                    <TextBlock Text="{Binding Level}" Margin="0,0,0,0" Foreground="{Binding LevelColor}" FontWeight="Bold" />
                                    <TextBlock Text="]" Foreground="#5B6B8A" Margin="2,0" />
                                    <TextBlock Text="{Binding Message}" Margin="10,0,0,0" TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
