<Window x:Class="LumbarMassageTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x4E0A;&#x6D77;&#x8212;&#x4E95;&#x6C14;&#x5BC6;&#x6027;&#x6D4B;&#x8BD5;&#x7CFB;&#x7EDF;" Height="1440" Width="3440" MinWidth="2560" MinHeight="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="NavButtonDefaultBrush" Color="#2B5EBE"/>
        <SolidColorBrush x:Key="NavButtonSelectedBrush" Color="#0E2F6C"/>
        <SolidColorBrush x:Key="NavButtonHoverBrush" Color="#3C74D9"/>
        <SolidColorBrush x:Key="NavButtonPressedBrush" Color="#0B2454"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource NavButtonDefaultBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0">
            <Grid>
                <Border Background="{StaticResource HeaderGradientBrush}"/>
                <Border Background="{StaticResource HeaderPatternBrush}" Opacity="0.25"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,10,0">
                        <Border Width="67" Height="45" Background="White" CornerRadius="20" Padding="2">
                            <Image Source="pack://application:,,,/舒井logo.jpg" Stretch="Uniform" Width="60" Height="36"/>
                        </Border>
                        <TextBlock Text="&#x4E0A;&#x6D77;&#x8212;&#x4E95;&#x6C14;&#x5BC6;&#x6027;&#x6D4B;&#x8BD5;&#x7CFB;&#x7EDF;" Foreground="White"
                                   FontSize="26" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 导航按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <Button Name="BtnTest" Content="测试界面" Style="{StaticResource NavButtonStyle}"
                                Click="BtnTest_Click"/>
                        <Button Name="BtnModel" Content="机型配方" Style="{StaticResource NavButtonStyle}" 
                                Click="BtnModel_Click"/>
                        <Button Name="BtnReport" Content="生产报表" Style="{StaticResource NavButtonStyle}" 
                                Click="BtnReport_Click"/>
                        <Button Name="BtnUser" Content="用户管理" Style="{StaticResource NavButtonStyle}"
                                Click="BtnUser_Click"/>
                        <Button Name="BtnSystemSettings" Content="系统设置" Style="{StaticResource NavButtonStyle}"
                                Click="BtnSystemSettings_Click"/>
                        <Button Name="BtnHelp" Content="使用帮助" Style="{StaticResource NavButtonStyle}"
                                Click="BtnHelp_Click"/>
                        <Button Name="BtnSystemLog" Content="系统日志" Style="{StaticResource NavButtonStyle}"
                                Click="BtnSystemLog_Click"/>
                    </StackPanel>

                    <!-- 用户信息 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Name="TxtCurrentUser" Text="当前用户: 未登录" Foreground="White" Style="{StaticResource StatusStyle}"/>
                        <Button Name="BtnLogout" Content="注销" Style="{StaticResource NavButtonStyle}" Click="BtnLogout_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <ContentControl Name="MainContentControl" Grid.Row="1" Background="{StaticResource SurfaceBlueBrush}"/>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{StaticResource BrandBlueDarkBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="TxtStatus" Text="系统就绪" Foreground="White" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="1" Name="TxtPLCStatus" Text="PLC: 未连接" Foreground="Red" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="2" Name="TxtMesStatusBar" Text="MES: 未连接" Foreground="Red" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="3" Name="TxtTime" Foreground="White" Style="{StaticResource StatusStyle}"/>
                <TextBlock Grid.Column="4" Foreground="White" Style="{StaticResource StatusStyle}"><Run Text="版本: v2.1."/><Run Language="zh-cn" Text="3"/></TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
