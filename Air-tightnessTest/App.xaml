<Application x:Class="LumbarMassageTest.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- 全局样式 -->
        <Color x:Key="BrandBlueColor">#1B4EA1</Color>
        <Color x:Key="BrandBlueDarkColor">#153E86</Color>
        <Color x:Key="BrandBlueLightColor">#2E6ED8</Color>
        <Color x:Key="SurfaceBlueColor">#EDF3FF</Color>
        <Color x:Key="SurfaceBorderColor">#C7D7F2</Color>
        <Color x:Key="AccentGreenColor">#1DB954</Color>
        <Color x:Key="AccentRedColor">#E04F4F</Color>

        <SolidColorBrush x:Key="BrandBlueBrush" Color="{StaticResource BrandBlueColor}"/>
        <SolidColorBrush x:Key="BrandBlueDarkBrush" Color="{StaticResource BrandBlueDarkColor}"/>
        <SolidColorBrush x:Key="BrandBlueLightBrush" Color="{StaticResource BrandBlueLightColor}"/>
        <SolidColorBrush x:Key="SurfaceBlueBrush" Color="{StaticResource SurfaceBlueColor}"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource SurfaceBorderColor}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRedColor}"/>

        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1F57B8" Offset="0"/>
            <GradientStop Color="#1A4C9C" Offset="1"/>
        </LinearGradientBrush>

        <DrawingBrush x:Key="HeaderPatternBrush" TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#3B6BD1" Thickness="1"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="0,40" EndPoint="40,0"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBlueBrush}"/>
        </Style>

        <Style TargetType="UserControl">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SoftButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E6EEFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2E3440"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Application.Resources>
</Application>
